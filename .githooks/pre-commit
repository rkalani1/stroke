#!/bin/sh
# Pre-commit leak guard — blocks staging real HMC/UW/Harborview institutional or
# PHI-adjacent content into this public repo. Defense-in-depth layer #4 (after
# .gitignore, the index.html host-gate, and the CI gate via `npm test`).
#
# Enable once per clone (also done automatically by `npm run hooks:install`):
#   git config core.hooksPath .githooks
#
# Scans only STAGED files, so it is fast and runs on every commit.

if command -v node >/dev/null 2>&1; then
  STAGED="$(git diff --cached --name-only --diff-filter=ACMR)"
  if [ -n "$STAGED" ]; then
    printf '%s\n' "$STAGED" | node ./scripts/check-no-institutional-leak.mjs
    if [ $? -ne 0 ]; then
      echo ""
      echo "❌ Commit blocked by leak guard. Real institutional content belongs in"
      echo "   private/institutional.js (gitignored), never in a committed file."
      echo "   To override a confirmed false-positive: refine scripts/leak-guard-denylist.json,"
      echo "   or (last resort) commit with --no-verify."
      exit 1
    fi
  fi
else
  echo "⚠️  pre-commit leak guard skipped: node not found on PATH."
fi
exit 0
