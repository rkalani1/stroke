#!/bin/sh
# Pre-commit leak guard -- blocks staging real local institutional or
# PHI-adjacent content into this public repo. Defense-in-depth layer #4 (after
# .gitignore, the index.html host-gate, and the CI gate via `npm test`).
#
# Enable once per clone (also done automatically by `npm run hooks:install`):
#   git config core.hooksPath .githooks
#
# Scans only STAGED files, so it is fast and runs on every commit.

if command -v node >/dev/null 2>&1; then
  if ! sh ./scripts/check-staged-leak-guard.sh; then
    echo ""
    echo "Commit blocked by leak guard. Real local protocol/contact/source"
    echo "   content belongs only in gitignored local extension files."
    echo "   To override a confirmed false-positive: refine the generic public denylist"
    echo "   or a gitignored private denylist,"
    echo "   or (last resort) commit with --no-verify."
    exit 1
  fi
else
  echo "⚠️  pre-commit leak guard skipped: node not found on PATH."
fi
exit 0
