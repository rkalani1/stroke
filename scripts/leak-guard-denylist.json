{
  "_comment": "Denylist for scripts/check-no-institutional-leak.mjs. Defense-in-depth #3 (after .gitignore and the index.html host-gate) protecting the PUBLIC GitHub Pages build + repo from ever leaking real HMC/UW/Harborview institutional or PHI-adjacent content. Real institutional protocols live ONLY in private/institutional.js (gitignored). Extend the arrays below as new institutional tokens are discovered; the scanner needs no code changes.",
  "_severityModel": "institutionalTokens are banned on the served/source surface but allowed in meta/policy files (see exemptFiles). phiPatterns are banned in EVERY tracked file with no exemption.",

  "institutionalTokens": [
    { "pattern": "\\bHarborview\\b", "flags": "i", "label": "Institution name: Harborview" },
    { "pattern": "\\bHMC\\b", "flags": "", "label": "Institution acronym: HMC (Harborview Medical Center)" },
    { "pattern": "\\bUWMC\\b", "flags": "", "label": "Institution acronym: UWMC" },
    { "pattern": "\\bUWML\\b", "flags": "", "label": "Institution acronym: UWML (UW Montlake)" },
    { "pattern": "\\bUWNW\\b", "flags": "", "label": "Institution acronym: UWNW (UW Northwest)" },
    { "pattern": "\\bUW-?NW\\b", "flags": "", "label": "Institution acronym: UW-NW" },
    { "pattern": "\\bUW Medicine\\b", "flags": "i", "label": "Institution name: UW Medicine" },
    { "pattern": "\\bUW Medical Center\\b", "flags": "i", "label": "Institution name: UW Medical Center" },
    { "pattern": "\\bUW Montlake\\b", "flags": "i", "label": "Institution name: UW Montlake" },
    { "pattern": "\\bOCCAM\\b", "flags": "", "label": "Local knowledge platform: OCCAM/Tactuum kit" },
    { "pattern": "\\bTactuum\\b", "flags": "i", "label": "Local knowledge-platform vendor: Tactuum" },
    { "pattern": "\\bMINUTE team\\b", "flags": "i", "label": "Local service line: MINUTE team" },
    { "pattern": "Emergency Stroke Panel", "flags": "i", "label": "Local EPIC panel: Emergency Stroke Panel" },
    { "pattern": "\\.UWM\\w*", "flags": "i", "label": "EPIC dotphrase: .UWM*" },
    { "pattern": "\\.Peds\\w*stroke", "flags": "i", "label": "EPIC dotphrase: .Pedsstroke" },
    { "pattern": "SmartSet", "flags": "i", "label": "EPIC build artifact: SmartSet" },
    { "pattern": "dotphrase", "flags": "i", "label": "EPIC build artifact: dotphrase" },
    { "pattern": "mission control", "flags": "i", "label": "Local ops: (Seattle Children's) Mission Control" }
  ],

  "phiPatterns": [
    { "pattern": "\\b206-\\d{3}-\\d{4}\\b", "flags": "", "label": "Seattle-area phone number (206-XXX-XXXX)" },
    { "pattern": "\\b425-\\d{3}-\\d{4}\\b", "flags": "", "label": "Seattle-area phone number (425-XXX-XXXX)" },
    { "pattern": "\\bpager\\b\\s*[:#]?\\s*\\d", "flags": "i", "label": "Pager number" },
    { "pattern": "keypad\\D{0,12}\\d", "flags": "i", "label": "Room keypad / access code (keypad + digits)" }
  ],

  "literalDenylist": [
    "206-744-6789",
    "206-459-4648",
    "206-987-8899",
    "4-2241",
    "4-8484",
    "304217",
    "304038"
  ],

  "_fullyExemptFiles": "The leak-guard's own machinery legitimately contains every banned token (it IS the ruleset). These files are skipped by BOTH the institutional and PHI scans. Keep this list minimal — only the guard's own files.",
  "fullyExemptFiles": [
    "scripts/leak-guard-denylist.json",
    "scripts/check-no-institutional-leak.mjs",
    ".githooks/pre-commit"
  ],

  "exemptFiles": [
    ".gitignore",
    "src/institutional-protocols.local.example.js",
    "scripts/check-no-institutional-leak.mjs",
    "scripts/leak-guard-denylist.json",
    "COMPLIANCE.md",
    "SECURITY.md",
    "tests/no-institutional-identifiers.test.js",
    "src/evidence/__tests__/eligibility-tables.test.js",
    "src/evidence/__tests__/screener-eval.test.js"
  ],

  "_institutionalScanExcludeDirs": "Institution-NAME tokens are governance-discussable in these dirs (internal planning/test/CI docs, never served by the app). PHI patterns + literals are STILL scanned here with no exemption.",
  "institutionalScanExcludeDirs": [
    "docs/",
    "tests/",
    ".github/"
  ],

  "binaryExtensions": [
    ".png", ".jpg", ".jpeg", ".gif", ".webp", ".ico", ".svg", ".pdf", ".docx",
    ".pptx", ".xlsx", ".gz", ".br", ".woff", ".woff2", ".ttf", ".otf", ".eot",
    ".mp4", ".webm", ".zip", ".keystore", ".jar"
  ]
